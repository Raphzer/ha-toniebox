{
  "name": "Home Assistant Tonies Dev",
  "dockerComposeFile": "docker-compose.yml",
  "service": "devcontainer",
  "workspaceFolder": "/workspaces/ha-toniebox",
  "postCreateCommand": "bash /workspaces/ha-toniebox/.devcontainer/post_create.sh",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.pylance",
        "esbenp.prettier-vscode",
        "redhat.vscode-yaml",
        "ms-python.black-formatter"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python3",
        "python.formatting.provider": "black",
        "editor.formatOnSave": true,
        "editor.rulers": [88]
      }
    }
  },
  "forwardPorts": [8123],
  "portsAttributes": {
    "8123": {
      "label": "Home Assistant UI",
      "onAutoForward": "openBrowser"
    }
  }
}